---
import Card from "@/components/landing/Card.astro";
import { getContent, type Lang } from "@/i18n/content";

const t = getContent(Astro.currentLocale as Lang).why;
---

<section id="why" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
	<div class="max-w-3xl">
		<h2>{t.title}</h2>
		<p class="text-muted-foreground mt-4 text-lg">{t.subtitle}</p>
		<p class="mt-6">{t.body}</p>
	</div>

	<div class="mt-10 grid gap-4 sm:grid-cols-3">
		{t.cards.map((card) => <Card title={card.title}>{card.body}</Card>)}
	</div>
</section>
