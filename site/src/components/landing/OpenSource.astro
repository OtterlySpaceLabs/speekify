---
import { buttonVariants } from "@/components/ui/button";
import { badgeVariants } from "@/components/ui/badge";
import { getContent, type Lang } from "@/i18n/content";

const repo = "https://github.com/OtterlySpaceLabs/speekify";
const t = getContent(Astro.currentLocale as Lang).openSource;
---

<section id="open-source" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
	<div class="flex flex-col items-center text-center">
		<span class={badgeVariants({ variant: "secondary" })}>{t.badge}</span>
		<h2 class="mt-6">{t.title}</h2>
		<p class="mx-auto mt-6 max-w-2xl">{t.body}</p>

		<div class="mt-8 flex flex-wrap items-center justify-center gap-3">
			<a href={repo} class={buttonVariants({ size: "lg" })}>{t.star}</a>
			<a href={`${repo}/issues`} class={buttonVariants({ variant: "outline", size: "lg" })}>{t.report}</a>
		</div>
	</div>
</section>
