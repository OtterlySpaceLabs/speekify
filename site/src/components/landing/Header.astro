---
import { buttonVariants } from "@/components/ui/button";
import { getContent, languages, type Lang } from "@/i18n/content";
import { getAlternates } from "@/i18n/utils";

const repo = "https://github.com/OtterlySpaceLabs/speekify";
const lang = (Astro.currentLocale ?? "en") as Lang;
const t = getContent(lang);
const alternates = getAlternates(Astro.url.pathname, lang);

const navLinks = [
	{ href: "#how", label: t.nav.how },
	{ href: "#cli", label: t.nav.cli },
	{ href: "#mcp", label: t.nav.mcp },
	{ href: "#install", label: t.nav.install },
];
---

<header
	class="animate-in fade-in slide-in-from-top-4 duration-500 bg-background/80 border-border sticky top-0 z-50 h-16 border-b backdrop-blur"
>
	<div class="mx-auto flex h-full max-w-6xl items-center justify-between gap-6 px-4 sm:px-6 lg:px-8">
		<a href="#top" class="text-lg font-semibold">Speekify</a>

		<nav class="text-muted-foreground flex items-center gap-6 text-sm max-md:hidden">
			{
				navLinks.map((link) => (
					<a href={link.href} class="hover:text-foreground transition">
						{link.label}
					</a>
				))
			}
		</nav>

		<div class="flex items-center gap-4">
			<nav aria-label="Language" class="text-muted-foreground flex items-center gap-2 text-sm max-md:hidden">
				{
					alternates.map((alt, index) => (
						<>
							{index > 0 && <span aria-hidden="true">/</span>}
							<a
								href={alt.rel}
								hreflang={alt.locale}
								aria-current={alt.locale === lang ? "true" : undefined}
								class:list={["hover:text-foreground transition", alt.locale === lang && "text-foreground font-medium"]}
							>
								{alt.locale.toUpperCase()}
								<span class="sr-only"> — {languages[alt.locale]}</span>
							</a>
						</>
					))
				}
			</nav>
			<a href={repo} class="text-muted-foreground hover:text-foreground flex items-center gap-1.5 text-sm max-md:hidden">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true">
					<path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.2 12.2 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"></path>
				</svg>
				{t.nav.github}
			</a>
			<a href="#install" class={buttonVariants({ size: "sm" })}>{t.nav.getStarted}</a>

			<details class="relative md:hidden">
				<summary class="text-muted-foreground hover:text-foreground flex size-8 cursor-pointer list-none items-center justify-center">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="size-5"
						aria-hidden="true"
					>
						<line x1="4" x2="20" y1="6" y2="6"></line>
						<line x1="4" x2="20" y1="12" y2="12"></line>
						<line x1="4" x2="20" y1="18" y2="18"></line>
					</svg>
					<span class="sr-only">{t.nav.menu}</span>
				</summary>
				<div class="bg-card border-border absolute top-full right-0 mt-2 flex w-44 flex-col gap-1 rounded-lg border p-2 text-sm shadow-lg">
					{
						navLinks.map((link) => (
							<a href={link.href} class="text-muted-foreground hover:bg-muted hover:text-foreground rounded-md px-3 py-2 transition">
								{link.label}
							</a>
						))
					}
					<a href={repo} class="text-muted-foreground hover:bg-muted hover:text-foreground flex items-center gap-2 rounded-md px-3 py-2 transition">
						<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-4" aria-hidden="true">
							<path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.2 12.2 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"></path>
						</svg>
						{t.nav.github}
					</a>
					<div class="border-border my-1 border-t"></div>
					{
						alternates.map((alt) => (
							<a
								href={alt.rel}
								hreflang={alt.locale}
								aria-current={alt.locale === lang ? "true" : undefined}
								class:list={[
									"rounded-md px-3 py-2 transition hover:bg-muted hover:text-foreground",
									alt.locale === lang ? "text-foreground font-medium" : "text-muted-foreground",
								]}
							>
								{languages[alt.locale]}
							</a>
						))
					}
				</div>
			</details>
		</div>
	</div>
</header>
