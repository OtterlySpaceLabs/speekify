---
import { buttonVariants } from "@/components/ui/button";
import CodeBlock from "@/components/landing/CodeBlock.astro";
import { getContent, type Lang } from "@/i18n/content";

const t = getContent(Astro.currentLocale as Lang).mcp;

const startServer = `speekify mcp                              # stdio — for local desktop AI clients
speekify mcp --transport streamable-http  # local HTTP endpoint`;

const addToClaude = "claude mcp add --transport stdio speekify -- speekify mcp";
---

<section id="mcp" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
	<div class="max-w-3xl">
		<h2>{t.title}</h2>
		<p class="text-muted-foreground mt-4 text-lg">{t.subtitle}</p>
		<p class="mt-6">{t.body}</p>
	</div>

	<div class="mt-10 grid gap-4 md:grid-cols-2">
		<CodeBlock label={t.startLabel} code={startServer} />
		<CodeBlock label={t.addLabel} code={addToClaude} />
	</div>

	<div class="mt-6">
		<a
			href="https://github.com/OtterlySpaceLabs/speekify/blob/main/docs/mcp-clients.md"
			class={buttonVariants({ variant: "link" })}
		>
			{t.perClient}
		</a>
	</div>
</section>
