---
const repo = "https://github.com/OtterlySpaceLabs/speekify";

const links = [
	{ href: repo, label: "GitHub" },
	{ href: `${repo}#readme`, label: "Documentation" },
	{ href: `${repo}/blob/main/docs/usage.md`, label: "CLI Reference" },
	{ href: `${repo}/blob/main/docs/mcp-clients.md`, label: "MCP Setup" },
];
---

<footer class="border-border border-t">
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
		<div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
			<div>
				<div class="text-lg font-semibold">Speekify</div>
				<p class="text-muted-foreground mt-2 text-sm">Open-source CLI that turns text into local audio.</p>
			</div>

			<nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
				{
					links.map((link) => (
						<a href={link.href} class="text-muted-foreground hover:text-foreground transition">
							{link.label}
						</a>
					))
				}
			</nav>
		</div>

		<div class="border-border mt-8 border-t pt-6">
			<p class="text-muted-foreground text-sm">MIT License · © 2026 Otterly Space SARL</p>
			<p class="text-muted-foreground mt-2 max-w-3xl text-xs">
				Speekify only fetches content you point it at, for your personal use. You're responsible for respecting
				the terms of service and copyright of any source you extract from.
			</p>
		</div>
	</div>
</footer>
