---
import { getContent, type Lang } from "@/i18n/content";

const repo = "https://github.com/OtterlySpaceLabs/speekify";
const t = getContent(Astro.currentLocale as Lang).footer;

const hrefs = [repo, `${repo}#readme`, `${repo}/blob/main/docs/usage.md`, `${repo}/blob/main/docs/mcp-clients.md`];
const links = hrefs.map((href, index) => ({ href, label: t.links[index] }));
---

<footer class="border-border border-t">
	<div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
		<div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
			<div>
				<div class="text-lg font-semibold">Speekify</div>
				<p class="text-muted-foreground mt-2 text-sm">{t.tagline}</p>
			</div>

			<nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
				{
					links.map((link) => (
						<a href={link.href} class="text-muted-foreground hover:text-foreground transition">
							{link.label}
						</a>
					))
				}
			</nav>
		</div>

		<div class="border-border mt-8 border-t pt-6">
			<p class="text-muted-foreground text-sm">{t.license}</p>
			<p class="text-muted-foreground mt-2 max-w-3xl text-xs">{t.disclaimer}</p>
		</div>
	</div>
</footer>
