---
import { getContent, type Lang } from "@/i18n/content";

const t = getContent(Astro.currentLocale as Lang).how;
---

<section id="how" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
	<div class="max-w-3xl">
		<h2>{t.title}</h2>
	</div>

	<ol class="mt-10 flex flex-col gap-6">
		{
			t.steps.map((step, index) => (
				<li class="flex items-start gap-4">
					<span class="bg-primary text-primary-foreground flex size-8 shrink-0 items-center justify-center rounded-full text-sm font-semibold">
						{index + 1}
					</span>
					<div>
						<div class="text-foreground text-base font-semibold">{step.title}</div>
						<p class="text-muted-foreground mt-1 text-sm leading-relaxed" set:html={step.body} />
					</div>
				</li>
			))
		}
	</ol>
</section>
