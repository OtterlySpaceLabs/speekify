---
import Card from "@/components/landing/Card.astro";
import { getContent, type Lang } from "@/i18n/content";

const t = getContent(Astro.currentLocale as Lang).useCases;
---

<section id="use-cases" class="mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
	<div class="max-w-3xl">
		<h2>{t.title}</h2>
	</div>

	<div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
		{t.cases.map((useCase) => <Card title={useCase.title}>{useCase.body}</Card>)}
	</div>
</section>
