---
interface Props {
	title?: string;
	eyebrow?: string;
}

const { title, eyebrow } = Astro.props;
---

<div class="bg-card border-border h-full rounded-xl border p-6">
	{eyebrow && <p class="text-muted-foreground text-xs tracking-wide uppercase">{eyebrow}</p>}
	{title && <div class="text-foreground mb-2 text-base font-semibold">{title}</div>}
	<div class="text-muted-foreground text-sm leading-relaxed">
		<slot />
	</div>
</div>
