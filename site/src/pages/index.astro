---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/landing/Header.astro";
import Hero from "@/components/landing/Hero.astro";
import Why from "@/components/landing/Why.astro";
import What from "@/components/landing/What.astro";
import HowItWorks from "@/components/landing/HowItWorks.astro";
import CliUsage from "@/components/landing/CliUsage.astro";
import Mcp from "@/components/landing/Mcp.astro";
import UseCases from "@/components/landing/UseCases.astro";
import Install from "@/components/landing/Install.astro";
import OpenSource from "@/components/landing/OpenSource.astro";
import Footer from "@/components/landing/Footer.astro";
---

<Layout
	title="Speekify — Turn text into local audio from your terminal"
	description="Speekify is an open-source CLI that turns articles, PDFs, YouTube transcripts, and piped text into a local audio file, synthesized on your own machine. Multilingual, with an MCP server for AI workflows."
>
	<Header />
	<main>
		<Hero />
		<Why />
		<What />
		<HowItWorks />
		<CliUsage />
		<Mcp />
		<UseCases />
		<Install />
		<OpenSource />
	</main>
	<Footer />
</Layout>
