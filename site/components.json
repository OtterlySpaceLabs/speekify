{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-vega",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/global.css",
    "baseColor": "neutral",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "hugeicons",
  "rtl": false,
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "menuColor": "default",
  "menuAccent": "subtle",
  "registries": {
    "@shadcn-studio": "https://shadcnstudio.com/r/radix-nova/{name}.json",
    "@ss-components": "https://shadcnstudio.com/r/components/radix-nova/{name}.json?email=${EMAIL}&license_key=${LICENSE_KEY}",
    "@ss-blocks": "https://shadcnstudio.com/r/blocks/radix-nova/{name}.json?email=${EMAIL}&license_key=${LICENSE_KEY}",
    "@ss-themes": "https://shadcnstudio.com/r/themes/{name}.json?email=${EMAIL}&license_key=${LICENSE_KEY}"
  }
}
